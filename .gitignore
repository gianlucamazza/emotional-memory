# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Testing & tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Local config — ignore everything under .claude/ except project-scoped skills
.claude/*
!.claude/skills/
.env

# IDE
.idea/
.vscode/
*.swp

# SQLite databases
*.db
*.sqlite

# pytest-benchmark results
.benchmarks/

# MkDocs build output
site/

# Paper — generated artefacts (keep LaTeX sources, ignore build outputs)
# Root-level build outputs from latexmk run outside paper/
main.aux
main.bbl
main.blg
main.fdb_latexmk
main.fls
main.log
main.out
main.synctex.gz
paper/tables/table*.md
paper/figures/*.png
paper/figures/*.pdf
docs/images/research/*.pdf
paper/main.pdf
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/_minted*/

# Coverage XML
coverage.xml

# Logs
*.log

# Release artefacts
.zenodo_doi
.release_state.json
.release_state*.bak

# Benchmark dry-run outputs — not evidence, use *.dryrun.* to protect from citation
benchmarks/locomo/results.dryrun.*
# Checkpoint files: intermediate resume state, not final evidence
benchmarks/locomo/results.checkpoint.jsonl
benchmarks/locomo/pareto_results.checkpoint.jsonl
benchmarks/locomo/routing_results.checkpoint.jsonl

# Editor/OS hygiene
*~
*.swo
.envrc
.python-version
.tox/
.coverage.*
Thumbs.db
desktop.ini
benchmark-results.json

# Benchmark smoke-run outputs (never committed)
benchmarks/**/*.dry.json
benchmarks/**/*.dry.md
