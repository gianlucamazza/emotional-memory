# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# Testing & tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Local config — ignore everything under .claude/ except project-scoped skills
.claude/*
!.claude/skills/
.env

# IDE
.idea/
.vscode/
*.swp

# SQLite databases
*.db
*.sqlite

# pytest-benchmark results
.benchmarks/

# MkDocs build output
site/

# Paper — generated artefacts (keep LaTeX sources, ignore build outputs)
paper/tables/table*.md
paper/figures/*.png
paper/figures/*.pdf
docs/images/research/*.pdf
paper/main.pdf
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/_minted*/

# Coverage XML
coverage.xml

# Release artefacts
.zenodo_doi
.release_state.json

# Benchmark dry-run outputs — not evidence, use *.dryrun.* to protect from citation
benchmarks/locomo/results.dryrun.*
# Checkpoint file: intermediate resume state, not final evidence
benchmarks/locomo/results.checkpoint.jsonl
