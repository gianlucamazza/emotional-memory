# emotional_memory — LLM configuration
# Copy to .env and fill in your values.
# .env is in .gitignore — never commit real keys.
#
# Used by:  examples/httpx_llm_integration.py
#           examples/llm_appraisal.py
#           make test-llm / make bench-appraisal

EMOTIONAL_MEMORY_LLM_API_KEY=

# Zenodo configuration (used for DOI deposit — see docs/research/ZENODO.md)
ZENODO_TOKEN=
EMOTIONAL_MEMORY_LLM_BASE_URL=https://api.openai.com/v1
EMOTIONAL_MEMORY_LLM_MODEL=gpt-5-mini
EMOTIONAL_MEMORY_LLM_OUTPUT_MODE=plain
EMOTIONAL_MEMORY_LLM_TIMEOUT_SECONDS=30
EMOTIONAL_MEMORY_LLM_REPEATS=3
