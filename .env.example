# emotional_memory — LLM configuration
# Copy to .env and fill in your values.
# .env is in .gitignore — never commit real keys.
#
# Used by:  examples/httpx_llm_integration.py
#           examples/llm_appraisal.py
#           make test-llm / make bench-appraisal
#           make zenodo-draft / make zenodo-publish
#
# Best practice:
#   - keep only local CLI secrets here
#   - prefer exporting release tokens in your shell for one-off publish commands
#   - never embed credentials in git remotes; use a credential helper or `hf auth login`

EMOTIONAL_MEMORY_LLM_API_KEY=

# Optional: manual PyPI fallback (`make publish-pypi-manual`)
PYPI_TOKEN=

# Zenodo configuration for manual DOI deposit
ZENODO_TOKEN=
ZENODO_BASE=https://zenodo.org
EMOTIONAL_MEMORY_LLM_BASE_URL=https://api.openai.com/v1
EMOTIONAL_MEMORY_LLM_MODEL=gpt-5-mini
EMOTIONAL_MEMORY_LLM_OUTPUT_MODE=plain
EMOTIONAL_MEMORY_LLM_TIMEOUT_SECONDS=30
EMOTIONAL_MEMORY_LLM_REPEATS=3
