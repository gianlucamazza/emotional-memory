{
  "study": "appraisal_confound",
  "dataset": "realistic_recall_v2",
  "dataset_version": "2.0",
  "embedder": "sbert-bge",
  "n_scenarios": 50,
  "n_queries": 200,
  "n_bootstrap": 10000,
  "seed": 42,
  "systems": {
    "aft_noAppraisal": {
      "n_queries": 200,
      "top1_accuracy": 0.595,
      "ci_95": {
        "point": 0.595,
        "ci_lower": 0.525,
        "ci_upper": 0.66,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      }
    },
    "aft_keyword": {
      "n_queries": 200,
      "top1_accuracy": 0.215,
      "ci_95": {
        "point": 0.215,
        "ci_lower": 0.16,
        "ci_upper": 0.275,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      }
    },
    "naive_cosine": {
      "n_queries": 200,
      "top1_accuracy": 0.47,
      "ci_95": {
        "point": 0.47,
        "ci_lower": 0.4,
        "ci_upper": 0.54,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      }
    }
  },
  "hypotheses": {
    "Hd2": {
      "description": "aft_noAppraisal.top1 > naive_cosine.top1, \u0394 > 0.10 (Addendum D generalization)",
      "result": "PASS",
      "delta": 0.125,
      "ci_95": {
        "point": 0.125,
        "ci_lower": 0.065,
        "ci_upper": 0.185,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      },
      "p_two_sided": 0.0,
      "cohens_d": 0.2865,
      "interpretation": "AFT architecture (no appraisal, preset affect) reliably outperforms naive cosine."
    },
    "Ha2": {
      "description": "aft_keyword.top1 > naive_cosine.top1 (\u0394 > 0.05, one-tailed alpha=0.05)",
      "result": "FAIL",
      "delta": -0.255,
      "ci_95": {
        "point": -0.255,
        "ci_lower": -0.33,
        "ci_upper": -0.18,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      },
      "p_one_sided": 0.0,
      "p_two_sided": 0.0,
      "cohens_d": -0.4724,
      "interpretation": "No significant advantage of AFT+keyword over naive cosine. Architecture benefit not confirmed on this dataset."
    },
    "Hb2": {
      "description": "|aft_keyword - aft_noAppraisal| < 0.05 (equivalence)",
      "result": "FAIL",
      "delta": -0.38,
      "ci_95": {
        "point": -0.38,
        "ci_lower": -0.46,
        "ci_upper": -0.3,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      },
      "p_two_sided": 0.0,
      "cohens_d": -0.6543,
      "interpretation": "Keyword appraisal meaningfully changes retrieval vs preset affect. Appraisal inference is not neutral."
    }
  }
}