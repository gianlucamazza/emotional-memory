{
  "study": "appraisal_confound",
  "dataset": "realistic_recall_v2_es",
  "dataset_version": "1.0",
  "embedder": "multilingual-e5-small",
  "n_scenarios": 20,
  "n_queries": 80,
  "n_bootstrap": 10000,
  "seed": 42,
  "systems": {
    "aft_noAppraisal": {
      "n_queries": 80,
      "top1_accuracy": 0.325,
      "ci_95": {
        "point": 0.325,
        "ci_lower": 0.225,
        "ci_upper": 0.425,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      }
    },
    "aft_keyword": {
      "n_queries": 80,
      "top1_accuracy": 0.0125,
      "ci_95": {
        "point": 0.0125,
        "ci_lower": 0.0,
        "ci_upper": 0.0375,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      }
    },
    "naive_cosine": {
      "n_queries": 80,
      "top1_accuracy": 0.2125,
      "ci_95": {
        "point": 0.2125,
        "ci_lower": 0.125,
        "ci_upper": 0.3,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      }
    }
  },
  "hypotheses": {
    "Hd2_ES": {
      "description": "aft_noAppraisal.top1 > naive_cosine.top1, \u0394 > 0.10 (Addendum D generalization)",
      "result": "FAIL",
      "delta": 0.1125,
      "ci_95": {
        "point": 0.1125,
        "ci_lower": -0.0125,
        "ci_upper": 0.2375,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      },
      "p_two_sided": 0.1095,
      "cohens_d": 0.189,
      "interpretation": "AFT without appraisal does not show a practically significant advantage over naive cosine at \u0394 > 0.10 threshold."
    },
    "Ha2": {
      "description": "aft_keyword.top1 > naive_cosine.top1 (\u0394 > 0.05, one-tailed alpha=0.05)",
      "result": "FAIL",
      "delta": -0.2,
      "ci_95": {
        "point": -0.2,
        "ci_lower": -0.3,
        "ci_upper": -0.1125,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      },
      "p_one_sided": 0.0001,
      "p_two_sided": 0.0001,
      "cohens_d": -0.4621,
      "interpretation": "No significant advantage of AFT+keyword over naive cosine. Architecture benefit not confirmed on this dataset."
    },
    "Hb2": {
      "description": "|aft_keyword - aft_noAppraisal| < 0.05 (equivalence)",
      "result": "FAIL",
      "delta": -0.3125,
      "ci_95": {
        "point": -0.3125,
        "ci_lower": -0.4125,
        "ci_upper": -0.2125,
        "ci_method": "bootstrap_percentile",
        "n_bootstrap": 10000
      },
      "p_two_sided": 0.0,
      "cohens_d": -0.67,
      "interpretation": "Keyword appraisal meaningfully changes retrieval vs preset affect. Appraisal inference is not neutral."
    }
  }
}